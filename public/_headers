/resources/*
  Cache-Control: public, no-cache

/enforce
  Integrity-Policy-WAICT-v1: manifest="/waict-manifest.json", blocked-destinations=(image script), mode=enforce, max-age=0, endpoints=(default)

/report
  Integrity-Policy-WAICT-v1: manifest="/waict-manifest-report.json", blocked-destinations=(image script), mode=report, max-age=0, endpoints=(default)
  Reporting-Endpoints: default="/reports"

